# ============================================================
# 温室 IoT 后端 — 环境变量
# 复制为 .env 并填写实际值
# ============================================================

# 服务端口
PORT=3000

# 微信小程序 AppId & AppSecret
WX_APPID=your_appid_here
WX_SECRET=your_secret_here

# JWT 密钥（随机生成一段长字符串）
JWT_SECRET=change_me_to_a_random_string

# MQTT Broker 连接
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# SQLite 数据库路径
DB_PATH=./data/greenhouse.db

# 设备离线阈值（秒）
DEVICE_OFFLINE_THRESHOLD=300

# 传感器数据清理（天）
SENSOR_RETENTION_DAYS=7

# CORS 允许的源（生产环境改为小程序合法域名）
CORS_ORIGIN=*
