/* ---- 状态栏 ---- */
.status-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
}

.device-name {
  font-size: 36rpx;
  font-weight: 700;
  flex: 1;
}

.online-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.online-badge.online {
  background: #d5f5e3;
  color: #27ae60;
}

.online-badge.offline {
  background: #fadbd8;
  color: #c0392b;
}

.last-update {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* ---- 网格布局 ---- */
.sensor-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.sensor-grid sensor-card {
  width: calc(50% - 8rpx);
}

/* ---- 手动控制卡片 ---- */
.control-card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  padding: 24rpx;
}

.control-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 16rpx;
}

.control-buttons {
  display: flex;
  justify-content: space-around;
}

/* ---- 快捷入口 ---- */
.quick-actions {
  margin-top: 32rpx;
}
