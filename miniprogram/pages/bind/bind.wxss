.intro {
  background: linear-gradient(135deg, #e8f8f0, #d5f5e3);
}

.intro-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--primary-dark);
  display: block;
  margin-bottom: 16rpx;
}

.intro-text {
  display: block;
  font-size: 26rpx;
  color: #555555;
  line-height: 1.8;
}

/* ---- 表单 ---- */
.input-group {
  margin-bottom: 16rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.error-msg {
  display: block;
  font-size: 24rpx;
  color: var(--danger);
  margin-top: 8rpx;
}
