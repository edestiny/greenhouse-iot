<!-- ============================================================
     个人中心
     ============================================================ -->
<view class="container">
  <!-- 用户信息 -->
  <view class="card user-header">
    <image class="avatar" src="{{userInfo.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill" />
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname || '温室主人'}}</text>
      <text class="uid">UID: {{userInfo.uid || '--'}}</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu card">
    <view class="menu-item" bindtap="onAlertHistory">
      <text>告警历史</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 其他 -->
  <view class="menu card mt-24">
    <view class="menu-item" bindtap="onAbout">
      <text>关于</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 退出 -->
  <view class="logout-section">
    <button class="btn btn-outline btn-block" bindtap="onLogout">退出登录</button>
    <text class="version">v{{appVersion}}</text>
  </view>
</view>
